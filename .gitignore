# Ignore all binary, intermediate, and cache folders
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Ignore compiled project files
*.VC.db
*.VC.VC.opendb
*.suo
*.user
*.userosscache
*.sln.docstates

# Ignore project-specific files generated by Unreal
*.xcodeproj
*.xcworkspace
*.opensdf
*.sdf
*.sln
*.suo
*.tmp
*.log
*.obj
*.pdb
*.idb
*.aps
*.ncb
*.ipch
*.tlog

# Ignore config files for IDEs and build tools
.vscode/
.idea/
*.swp
*.DS_Store
Thumbs.db

# Ignore backup and autosave files
*.bak
*.tmp
*.orig
*.old
*.autosave

# Ignore Unreal Engine auto-generated assets
*.uasset
*.umap

# Ignore compiled binaries
*.exe
*.dll
*.lib
*.app
*.dylib
*.so

# Ignore Unreal crash reports
CrashReportClient/Saved/

# Ignore .uproject local settings
*.uprojectdirs